# Copy this file to `.env` and adjust values as needed.
# Never commit your real `.env` file.

# ============================================================
# ai_core -- Gemini / LangGraph / checkpointing
# ============================================================
GOOGLE_API_KEY=your-key-here
HOMEMIND_ENV=development
POSTGRES_CONN_STRING=
SQLITE_DB_PATH=homemind_dev.db
SUMMARIZE_TRIGGER_TURNS=8

# ============================================================
# RAG / Knowledge Agent module
# ============================================================
DOCUMENTS_DIR=rag/documents
VECTOR_DB_DIR=rag/vectordb/store
LOG_DIR=logs

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

CHUNK_SIZE=500
CHUNK_OVERLAP=100

TOP_K=5

LOG_LEVEL=INFO
